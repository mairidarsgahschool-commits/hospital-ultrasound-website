# =====================================================
# Hospital Ultrasound Report Generator - Configuration
# =====================================================

# === SERVER CONFIGURATION ===
NODE_ENV=development
PORT=5000
HOST=localhost

# === SECURITY ===
SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# === DATABASE CONFIGURATION ===
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hospital_ultrasound
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_DIALECT=postgres
DB_SSL=false

# === EMAIL CONFIGURATION ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
EMAIL_FROM=Hospital Ultrasound <noreply@hospital-ultrasound.com>

# === FILE UPLOAD ===
MAX_FILE_SIZE=50mb
UPLOAD_DIR=./uploads
ALLOWED_IMAGE_TYPES=jpeg,jpg,png,dcm

# === FRONTEND CONFIGURATION ===
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# === AWS S3 (Optional - for production image storage) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=hospital-ultrasound-images

# === LOGGING ===
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# === PAGINATION ===
PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# === REDIS (Optional - for caching) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === CORS ===
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# === API RATE LIMITING ===
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# === TIMEZONE ===
TIMEZONE=UTC
