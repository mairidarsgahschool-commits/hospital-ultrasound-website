{
  "name": "hospital-ultrasound-backend",
  "version": "1.0.0",
  "description": "Backend API for Hospital Ultrasound Report Generator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.js\""
  },
  "keywords": [
    "hospital",
    "ultrasound",
    "reports",
    "medical",
    "healthcare"
  ],
  "author": "Hospital IT Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "pg": "^8.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.0",
    "nodemailer": "^6.9.1",
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0",
    "joi": "^17.9.2",
    "sequelize": "^6.31.2",
    "pdfkit": "^0.13.0",
    "redis": "^4.6.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.43.0",
    "prettier": "^2.8.8"
